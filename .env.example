# vlad-chess-coach — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to GitHub — it's in .gitignore.

# ── Gemini API (required) ─────────────────────────────────────────────────
# Powers Vlad, Fabiano, and Magnus coach personas at runtime.
# Get key: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── YouTube Data API v3 (optional) ───────────────────────────────────────
# Enables GM example game search in VideoLibrary.
# Get key: https://console.cloud.google.com → YouTube Data API v3
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Chess.com API ─────────────────────────────────────────────────────────
# Chess.com Public API requires no key — just a User-Agent header.
# Already configured in src/api/chesscom.js.
# CHESS_COM_USERNAME=TopherBettis  ← hardcoded in chesscom.js

# ── App config (optional overrides) ──────────────────────────────────────
VITE_PLAYER_USERNAME=TopherBettis
VITE_TARGET_ELO=2000
